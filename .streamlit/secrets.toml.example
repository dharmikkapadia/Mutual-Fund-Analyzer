# Copy this to .streamlit/secrets.toml (which is gitignored) to enable the
# optional encrypted, cross-device watchlist sync. WITHOUT this section the app
# works exactly as before (browser localStorage only) and the cloud-sync UI is
# hidden.
#
# On Streamlit Community Cloud, paste these values into:
#   App  ->  Settings  ->  Secrets
#
# The `repo` MUST be a PRIVATE repo you own (not this public one). User
# watchlists are encrypted in the app before upload, but keeping the store
# private adds a second layer of protection.

[sync]
# A fine-grained Personal Access Token scoped to ONLY the private store repo,
# with Repository permissions: Contents = Read and write.
# Create at: https://github.com/settings/personal-access-tokens
token  = "github_pat_xxxxxxxxxxxxxxxxxxxxxxxx"

# owner/name of the PRIVATE repo that holds the encrypted blobs.
repo   = "your-username/mfa-watchlists-private"

# Branch to write to (optional; defaults to "main").
branch = "main"

# ---------------------------------------------------------------------------
# OPTIONAL: outbound proxy for the PF-Review Value Research fetch.
#
# Value Research's bot protection usually blocks cloud/datacenter IPs
# (Streamlit Cloud, AWS, GCP...), so 'Fetch from Value Research' fails there
# with HTTP 403 even though the same fetch works from a home connection.
# Setting a proxy with a RESIDENTIAL/ISP IP (from a proxy provider — these
# are the provider's credentials, NOT any Value Research login) routes only
# the VR traffic through it. Without this section the fetch goes direct.
#
# Recommended form — each value is taken literally, so passwords with
# special characters (#, @, /, :) need no escaping:
#
# [vr]
# proxy_host = "gate.example-proxy.com"
# proxy_port = 7000
# proxy_user = "sp1abc23"
# proxy_pass = "pa#ss@word"        # fine as-is here
# # proxy_scheme = "http"          # optional, defaults to http
#
# Alternative single-URL form (credentials are auto percent-encoded):
# [vr]
# proxy = "http://username:password@proxy-host:port"
